{
  "manifest_version": 3,
  "name": "CAO",
  "version": "1.0.0",
  "description": "全自动识别并隐藏 X/Twitter 上的广告推荐和垃圾内容，装上一键屏蔽。",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "cookies"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://www.x.com/*",
    "https://www.twitter.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "block.html",
        "block.css",
        "block.js"
      ],
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.x.com/*",
        "https://www.twitter.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.x.com/*",
        "https://www.twitter.com/*"
      ],
      "js": [
        "block-engine.js",
        "spam-engine.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
